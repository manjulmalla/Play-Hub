# PlayHub environment configuration sample.
# Copy this file to `.env` and adjust values for your local setup.

# Django secret key - generate a strong random value in production.
SECRET_KEY=django-insecure-change-me-to-a-long-random-string

# Set to False in production and True for local development.
DEBUG=True

# Comma separated list of allowed hosts.
ALLOWED_HOSTS=127.0.0.1,localhost

# Optional FFmpeg binary path. Leave empty to auto-detect from PATH.
FFMPEG_PATH=
